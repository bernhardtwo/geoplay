# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
wheels/
*.egg-info/
.installed.cfg
MANIFEST

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# uv
# -----------------------------------------------------------------------------
# Lock file IS committed; just ignore the cache
.uv-cache/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# -----------------------------------------------------------------------------
# Type checking
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -----------------------------------------------------------------------------
# Data (do NOT commit datasets to a Python repo)
# -----------------------------------------------------------------------------
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/processed/features.parquet

# -----------------------------------------------------------------------------
# ML artifacts
# -----------------------------------------------------------------------------
mlruns/
mlartifacts/
models/*.pkl
models/*.joblib
models/*.bin
models/*.onnx
*.h5
*.pt
*.pth
*.ckpt

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# IDE / editors
# -----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
